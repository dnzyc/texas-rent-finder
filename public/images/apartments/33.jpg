StdOffset); var endDateInOffsetM = endDateInM.utcOffset(endDateStdOffset); } else { var startDateInOffsetM = originalStartM; var endDateInOffsetM = originalEndM; } timeOutput += startDateInOffsetM.format('h'); if (startDateInOffsetM.format('mm') != "00") { timeOutput += startDateInOffsetM.format(':mm'); } if (startDateInOffsetM.format('a') != endDateInOffsetM.format('A')) { timeOutput += startDateInOffsetM.format(' A'); } } return timeOutput; } var currentDataURL = "https://www.templecollege.edu/events/_data/current-live.json"; var hhEventsType = "filter"; var hhEventsLimit = 8; /* var hhEventsWidth = "${hhEventsWidth}"; */ var hhEvents = []; var filter1Text = [ "community", "templecollege", "academic"]; var filter5Text = [ ]; var filter1 = true; var filter2 = false; var filter3 = false; var filter4 = false; var filter5 = true; var filter6 = false; var filter7 = false; var filter8 = false; var filter9 = false; var filter10 = false; var hhEventsFilterLogic = "Or"; var filterTexts = [ filter1Text,false,false,false,filter5Text,false,false,false,false,false ]; var filterTextsAll = _.flatMap(_.compact(filterTexts)); /*console.log(filterTextsAll);*/ function afterHHEventsLoad(){ $('.hh-events.hh-events-block .event .title').matchHeight(); }</script>        <script src="https://www.templecollege.edu/events/_files/js/hh-events.js" type="text/javascript"></script>

