	<script>
		for (let ctaButton of document.querySelectorAll(".sys-cta-button"))
		{
			ctaButton.addEventListener('click', function() {
				var addedCrossSells = new Set([]);
				var storedSelections = localStorage.getItem('gmAddedCrossSells');
				if (storedSelections)
					addedCrossSells = new Set(JSON.parse(storedSelections));

				var selectedProductId = this.dataset.selected_product;
				if(selectedProductId)
					addedCrossSells.add(selectedProductId);

				localStorage.setItem("gmAddedCrossSells", JSON.stringify(Array.from(addedCrossSells)));

				let permalink = this.dataset.permalink;
				if (!permalink) return;
				setTimeout(() => {
					window.location.href = permalink;
				}, 75);
			});
		}
	</script>


	
