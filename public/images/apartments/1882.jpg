	padding: 0 15px;
}

.promo-details .terms-conditions a {
	text-decoration: underline;
	color: #8d2121;
}

.two-col-w-product-cta .columns:last-child {
  margin-bottom: 0px;
}

.primary-deal .product-image {
	align-self: center;
}

.secondary-deals .product-name {
	text-align: center;
}

.sale-page .sale-content {
	margin: 1.5em 1em;
}


@media (min-width: 768px) {
	.sale-page .sale-content {
	margin: 1.5em auto;
}
}


.product-compare-boxes .card-promo-area {
	display: none!important;
}

