</div>
</section>
<button class="sc20-bttn cgrid-3" aria-controls="brand-compliance">
<ws-icon ico="retail"></ws-icon>
<h3>Brand compliance</h3>
</button>
<!-- SC01v2 -->
<section class="sc01 sc01v2 panelcontent cpad" data-ocomid="sc01" id="brand-compliance">
<div class="cwidth">
<div class="sc01-3col">
<div class="sc01-citem">
<h5>Brand Compliance Management</h5>
<p>Ethically manage your product lifecycle, maintaining compliance while improving financial performance.</p>
<p><a href="/retail/brand-compliance/" data-lbl="brand-compliance-xlnk">Explore brand compliance management</a></p>
</div>
<div class="sc01-citem">
<h5>Resources</h5>
<ul class="nobullets">
