  }

  .max-plan-picker-group [class*="value-prop-"] span.small {
    color: rgba(0, 0, 0, .6);
    font-size: .85em;
  }

  /* Plan Picker - Legal Text */
  .max-plan-picker-wrapper p.legal.small {
    max-width: 100ch;
  }
  
</style>

<!-- Plan Picker HTML -->

<div id="plan-picker" class="container">
  <div class="row">
    <div class="col-lg-12 mx-auto">
      <div class="text-center mb-3">
        <h2>Find Your Perfect Plan</h2>
      </div>
      <div class="max-plan-picker-wrapper">
        <!-- Plan Picker Cards -->
        <section class="max-plan-picker-group row" data-plan-group="monthly">
          <div class="max-plan-picker-card-group col-12">
            <div class="max-plan-picker-card-wrapper">
              <div id="ad-lite-monthly" class="max-plan-picker-group__card d-flex flex-column align-items-start justify-content-start">
                <div class="text rich-text">
                  <h3>discovery+</h3>
                  <ul class="value-props-list">
                    <p class="plan-description">Unlimited access to the greatest real-life entertainment plus exclusives and originals, all in one place.</p>
                  </ul>
                </div>
                <div class="price-plan-button-row d-flex justify-content-between">
                  <div class="text rich-text">
                    <h4><sup>$</sup>5.99<em>/month</em></h4>
                  </div>
                  <a class="select-plan-btn btn px-4 btn--primary btn-md" target="_top" role="button" rel="noopener" aria-label="Select the ad-lite plan for $5.99 a month" href="https://auth.discoveryplus.com/product?route=ad-lite-monthly">Start 7-Day Free Trial</a>
                </div>
              </div>
            </div>
            <div class="max-plan-picker-card-wrapper">
              <div id="ad-free-monthly" class="max-plan-picker-group__card d-flex flex-column align-items-start justify-content-start">
                <div class="text rich-text">
                  <h3>discovery+ (Ad-Free)</h3>
                  <ul class="value-props-list">
                    <p class="plan-description">Unlimited access to all that discovery+ has to offer - without the ads!</p>
                  </ul>
                </div>
                <div class="price-plan-button-row d-flex justify-content-between">
                  <div class="text rich-text">
                    <h4><sup>$</sup>9.99<em>/month</em></h4>
                  </div>
                  <a class="select-plan-btn btn px-4 btn--primary btn-md" target="_top" role="button" rel="noopener" aria-label="Select the ad-free plan for $9.99 a month" href="https://auth.discoveryplus.com/product?route=ad-free-monthly">Start 7-Day Free Trial</a>
                </div>
              </div>
            </div>
          </div>
        </section>
        <!-- Legal: Monthly Plans -->
        <section class="max-plan-picker-aux-display row d-none" data-plan-groups-aux-display="monthly">
          <div class="col-12 mt-3 mb-5">
            <p class="legal small">Free trial available to new subscribers.<a href="https://www.discoveryplus.com/terms">Terms apply</a>.</p>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>

</div></div></div></div></section><section class="band Band-sc-xemrno-0 dTudhy max-section-gallery-parent" id="page230-band8095"><div class="py-5 container max-section-gallery"><div id="layout-8095" class="Layoutstyles__StyledDiv-sc-1jqq8jz-0 ieEcMe layout row d-flex"><div class="d-flex flex-column col-md-12 align-items-start justify-content-start Column-sc-1l90ivv-0"><div class="Textstyles__Wrapper-sc-1psu1wr-0 kZwSuq text rich-text w-100 w-100" data-isrtl="false" id="page230-band8095-Text8096"><div class="text-center"><h2>Stream Originals from CNN</h2></div></div><div class="w-100 Carousel-sc-1clq0zq-0 kVoRTM carousel slide"><ol class="carousel-indicators"><li class="active"></li><li class=""></li><li class=""></li><li class=""></li><li class=""></li></ol><div class="carousel-inner"><div class="carousel-item active"><div class="Imagestyles__Image-sc-gsk5g-0 godgEb initial-img-wrapper"><img id="page230-band8095-Image8097" alt="Anthony Bourdain: Parts Unknown" class="img img-fluid lozad Imagestyles__Image-sc-gsk5g-0 godgEb" height="2160" sizes="100vw" width="3840" data-src="https://beam-images.warnermediacdn.com/2025-02/ba3d4531-ebda-3a7d-b84f-25b8af1ac6f2.jpeg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com&amp;w=480" data-srcset="https://beam-images.warnermediacdn.com/2025-02/ba3d4531-ebda-3a7d-b84f-25b8af1ac6f2.jpeg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com&amp;w=480 480w, https://beam-images.warnermediacdn.com/2025-02/ba3d4531-ebda-3a7d-b84f-25b8af1ac6f2.jpeg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com&amp;w=960 960w, https://beam-images.warnermediacdn.com/2025-02/ba3d4531-ebda-3a7d-b84f-25b8af1ac6f2.jpeg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com&amp;w=1200 1200w"/></div></div><div class="carousel-item"><div class="Imagestyles__Image-sc-gsk5g-0 godgEb initial-img-wrapper"><img id="page230-band8095-Image8098" alt="Amanpour: Sex &amp; Love" class="img img-fluid lozad Imagestyles__Image-sc-gsk5g-0 godgEb" height="2160" sizes=