":\\\"https://beam-images.warnermediacdn.com/2025-11/Desktop_ContentQuilt_EntSports-Gradient.jpg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com\\\",\\\"height\\\":\\\"1084\\\",\\\"width\\\":\\\"1920\\\"}}}]}\"},{\"componentID\":\"7982\",\"property\":\"script\",\"value\":\"\u003cscript\u003e\\r\\n//My custom JS code for Barbie\\r\\nwindow.addEventListener(\\\"loadCustomCode\\\", function() {\\r\\n   \\r\\n  // Gallery Accesability\\r\\n\\r\\n    // select all the arrow controls from all carousels\\r\\n    const nextArrowControls = Array.from(document.querySelectorAll('a.carousel-control-next'));\\r\\n    const prevArrowControls = Array.from(document.querySelectorAll('a.carousel-control-prev'));\\r\\n    const allArrowControls = [...nextArrowControls, ...prevArrowControls];\\r\\n\\t\\t\\r\\n\\t\\t// hide arrow span elements from screenreader\\r\\n\\t\\tconst arrowSpans = Array.from(document.querySelectorAll('.sr-only'));\\r\\n\\t\\tarrowSpans.forEach(arrow =\u003e arrow.setAttribute('aria-hidden', 'true'));\\r\\n\\r\\n    // Remove arrows from tab flow\\r\\n\\t\\tallArrowControls.forEach(control =\u003e {\\r\\n\\t\\t\\tcontrol.setAttribute('tabindex', '-1');\\r\\n\\t\\t\\tcontrol.setAttribute('aria-hidden', 'true');\\r\\n\\t\\t});\\r\\n\\r\\n    // select all the lists of indicators\\r\\n    const carouselIndicatorsLists = document.querySelectorAll('ol.carousel-indicators');\\r\\n    carouselIndicatorsLists.forEach(function(list) {\\r\\n\\r\\n    // remove the list from tab flow\\r\\n    list.setAttribute('tabindex', '-1');\\r\\n\\r\\n    // move the list to the bottom of the carousel dom, to optimize tab flow\\r\\n    list.parentElement.appendChild(list);\\r\\n\\r\\n    // select all the items/carousel indicators, in this list\\r\\n    const carouselIndicators = list.querySelectorAll('li');\\r\\n\\r\\n    // count them\\r\\n    const numCarouselIndicators = carouselIndicators.length;\\r\\n\\r\\n    // get the carousel slides contents\\r\\n    const carouselItems = list.parentElement.querySelector('.carousel-inner').children;\\r\\n\\r\\n    // loop thru indicators\\r\\n    carouselIndicators.forEach(function(indicator, index) {\\r\\n\\r\\n      // get image alt text and slide count to populate indicator aria-label\\r\\n      const targetCarouselItem = carouselItems[index];\\r\\n      const targetCarouselLink = targetCarouselItem.querySelector('a');\\r\\n      const imageAltText = carouselItems[index].querySelector('img').getAttribute('alt');\\r\\n      const ariaLabelContent = imageAltText; \\r\\n      indicator.setAttribute('aria-label', ariaLabelContent);\\r\\n      \\r\\n      // put indicator into tab flow\\r\\n      indicator.setAttribute('tabindex', '0');\\r\\n\\r\\n      // add focus event to indicators, \\r\\n      // so keyboard users will experience the slides - not just the dots\\r\\n      indicator.addEventListener('focus', (event) =\u003e {\\r\\n        indicator.click();\\r\\n      });\\r\\n      \\r\\n      // add keydown event to indicators; press enter\\r\\n      indicator.addEventListener('keydown', (event) =\u003e {\\r\\n        // if focused on an active indicator, and the indicator has an associated slide link\\r\\n        // focus on the link when Enter key is pressed\\r\\n        if (event.key === 'Enter' \u0026\u0026 indicator.classList.contains('active') \u0026\u0026 targetCarouselLink) {\\r\\n          targetCarouselLink.focus();\\r\\n        } \\r\\n      });\\r\\n\\r\\n    });\\r\\n\\r\\n\\r\\n\\t\\t//\\r\\n\\t\\t// SCROLL IN VIEW ANIMATION\\r\\n\\t\\t//  \\r\\n\\t\\tconst slideElements = [\\r\\n\\t\\t\\t{ selector: \\\".max-section-character-carousel h2, .max-section-gallery h2, .max-section-trailer h2\\\", classes: ['element-scroll', 'slide-right'] },\\r\\n\\t\\t\\t{ selector: \\\".max-section-asl img, .max-section-asl .text, .max-section-asl a\\\", classes: ['element-scroll', 'slide-up'] },\\r\\n\\t\\t\\t{ selector: \\\".max-section-character-carousel .character-carousel-inner\\\", classes: ['element-scroll', 'slide-up-char01'] },\\r\\n\\t\\t\\t{ selector: \\\".max-section-character-carousel p\\\", classes: ['element-scroll', 'slide-up-char02'] },\\r\\n\\t\\t\\t{ selector: \\\".max-section-gallery .carousel, .max-section-trailer a\\\", classes: ['element-scroll', 'scale-up'] },\\r\\n\\t\\t\\t{ selector: \\\".max-section-character-carousel button\\\", classes: ['element-scroll'] },\\r\\n\\t\\t];\\r\\n\\r\\n\\t\\tslideElements.forEach((element) =\u003e {\\r\\n\\t\\t\\tconst elements = document.querySelectorAll(element.selector);\\r\\n\\t\\t\\telements.forEach((el) =\u003e {\\r\\n\\t\\t\\t\\tel.classList.add(...element.classes);\\r\\n\\t\\t\\t});\\r\\n\\t\\t});\\r\\n\\r\\n\\t\\tconst scrollElements = document.querySelectorAll(\\\".element-scroll\\\");\\r\\n\\t\\t\\t\\t\\t\\t\\r\\n\\t\\tconst elementInView = (el, dividend = 1) =\u003e {\\r\\n\\t\\t\\tconst elementTop = el.getBoundingClientRect().top;    \\r\\n\\t\\t\\treturn (\\r\\n\\t\\t\\t\\telementTop \u003c=\\r\\n\\t\\t\\t\\t(window.innerHeight || document.documentElement.clientHeight) / dividend\\r\\n\\t\\t\\t);\\r\\n\\t\\t};\\r\\n\\t\\t\\t\\t\\r\\n\\t\\tconst elementOutofView = (el) =\u003e {\\r\\n\\t\\t\\tconst elementTop = el.getBoundingClientRect().top;  \\r\\n\\t\\t\\treturn (\\r\\n\\t\\t\\t\\telementTop \u003e (window.innerHeight || document.documentElement.clientHeight)\\r\\n\\t\\t\\t);\\r\\n\\t\\t};\\r\\n\\t\\t\\t\\t\\r\\n\\t\\tconst displayScrollElement = (element) =\u003e {\\r\\n\\t\\t\\telement.classList.add(\\\"scrolled\\\");\\r\\n\\t\\t};\\r\\n\\t\\t\\t\\t\\r\\n\\t\\tconst hideScrollElement = (element) =\u003e {\\r\\n\\t\\t\\telement.classList.remove(\\\"scrolled\\\");\\r\\n\\t\\t};\\r\\n\\t\\t\\t\\t\\r\\n\\t\\tconst elementScrollAnimation = () =\u003e {\\r\\n\\t\\t\\tscrollElements.forEach((el) =\u003e {\\r\\n\\t\\t\\t\\tif (elementInView(el, 1.1)) {\\r\\n\\t\\t\\t\\t\\tdisplayScrollElement(el);\\r\\n\\t\\t\\t\\t} else if (elementOutofView(el)) {\\r\\n\\t\\t\\t\\t\\thideScrollElement(el)\\r\\n\\t\\t\\t\\t}\\r\\n\\t\\t\\t})\\r\\n\\t\\t}\\r\\n\\t\\t\\t\\t\\r\\n\\t\\twindow.addEventListener(\\\"scroll\\\", () =\u003e { \\r\\n\\t\\t\\telementScrollAnimation();\\r\\n\\t\\t});\\r\\n  });\\r\\n});\\r\\n\\r\\n\u003c/script\u003e\"},{\"componentID\":\"7982\",\"property\":\"code\",\"value\":\"\u003cstyle\u003e\\r\\n.section-collection-hero-parent::before {\\r\\n    background-image: linear-gradient(45deg, rgba(26,28,33,0.92), rgba(26,28,33,0.2)), linear-gradient(0deg, #1a1c21 30%, transparent 50%);\\r\\n    content: \\\"\\\";\\r\\n    height: 100%;\\r\\n    position: absolute;\\r\\n    width: 100%;\\r\\n    z-index: 0;\\r\\n}\\r\\n\\r\\n.logo .img{\\r\\n    max-width: 50%;\\r\\n}\\r\\n\\r\\n/* Carousel Accessibility*/\\r\\n\\r\\n/**\\r\\n* ----------------------------------------\\r\\n* ALL GALLERY'S\\r\\n* ----------------------------------------\\r\\n*/\\r\\n\\r\\n.max-section-gallery .carousel {\\r\\n  overflow: visible !important;\\r\\n  margin-right: 1.5rem;\\r\\n}\\r\\n.max-section-gallery .carousel-inner {\\r\\n  overflow: hidden !important;\\r\\n}\\r\\n\\r\\n@media (max-width: 767px) {\\r\\n\\t.max-section-gallery-parent .max-section-gallery {\\r\\n\\t\\tpadding: 0rem 0 7rem 0 !important;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel {\\r\\n\\t\\tmargin-right: 0;\\r\\n\\t}\\r\\n}\\r\\n\\r\\n/**\\r\\n* ----------------------------------------\\r\\n* GALLERY CAROUSEL\\r\\n* ----------------------------------------\\r\\n*/\\r\\n.max-section-gallery .carousel-control-prev-icon, .max-section-gallery .carousel-control-next-icon {\\r\\n\\twidth: 50px;\\r\\n\\theight: 50px;\\r\\n\\ttransition: all 0.5s ease;\\r\\n  -webkit-transition: all 0.5s ease;\\r\\n}\\r\\n.max-section-gallery .carousel .carousel-control-prev,\\r\\n.max-section-gallery .carousel .carousel-control-next {\\r\\n\\tcursor: pointer;\\r\\n\\twidth: auto !important;\\r\\n\\tz-index: 10;\\r\\n\\topacity: 1 !important;\\r\\n\\ttop: 50%;\\r\\n\\ttransform: translateY(-50%);\\r\\n\\tbackground-image: none !important;\\r\\n\\ttransition: all 0.5s ease;\\r\\n  -webkit-transition: all 0.5s ease;\\r\\n}\\r\\n.max-section-gallery .carousel .carousel-control-prev:focus-visible span,\\r\\n.max-section-gallery .carousel .carousel-control-next:focus-visible span {\\r\\n\\tbox-shadow: rgb(255, 255, 255) 0px 0px 0px 2px, rgb(0, 0, 0) 0px 0px 0px 5px !important;\\r\\n\\tborder-radius: 10px !important;\\r\\n\\toutline: none;\\r\\n}\\r\\n.max-section-gallery .carousel .carousel-control-prev {\\r\\n\\tleft: -9%;\\r\\n}\\r\\n.max-section-gallery .carousel .carousel-control-next {\\r\\n\\tright: -9%;\\r\\n}\\r\\n.max-section-gallery .carousel .carousel-control-prev-icon:hover { \\r\\n\\ttransform: rotate(90deg) translateY(15%) !important;\\r\\n}\\r\\n.max-section-gallery .carousel .carousel-control-next-icon:hover { \\r\\n\\ttransform: rotate(270deg) translateY(15%) !important;\\r\\n}\\r\\n\\r\\n/* Carousel Indicators */\\r\\n.max-section-gallery .carousel-indicators {\\r\\n\\ttop: 105% !important;\\r\\n}\\r\\n.max-section-gallery .carousel-indicators li {\\r\\n\\tbackground-color: white !important;\\r\\n\\twidth: 18px !important;\\r\\n\\theight: 18px !important;\\r\\n\\tmargin-left: 6px !important;\\r\\n\\tmargin-right: 6px !important;\\r\\n\\tborder: 0;\\r\\n}\\r\\n.max-section-gallery .carousel-indicators li:focus-visible {\\r\\n\\tbox-shadow: rgb(255, 255, 255) 0px 0px 0px 1px, rgb(0, 0, 0) 0px 0px 0px 4px, rgb(255, 255, 255) 0px 0px 0px 6px !important;\\r\\n\\toutline: none;\\r\\n}\\r\\n\\r\\n\\r\\n@media (max-width: 991px) {\\r\\n\\t.max-section-gallery .carousel .carousel-control-prev {\\r\\n\\t\\tleft: -11%;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel .carousel-control-next {\\r\\n\\t\\tright: -11%;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel-indicators {\\r\\n\\t\\ttop: 111% !important;\\r\\n\\t}\\r\\n}\\r\\n@media (max-width: 767px) {\\r\\n\\t.max-section-gallery .carousel-control-prev-icon, .max-section-gallery .carousel-control-next-icon {\\r\\n\\t\\twidth: 30px;\\r\\n\\t\\theight: 30px;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel .carousel-control-prev,\\r\\n\\t.max-section-gallery .carousel .carousel-control-next {\\r\\n\\t\\ttop: 113%;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel .carousel-control-prev {\\r\\n\\t\\tleft: 25%;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel .carousel-control-next {\\r\\n\\t\\tright: 25%;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel-indicators {\\r\\n\\t\\ttop: 110% !important;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel-indicators li {\\r\\n\\t\\twidth: 14px !important;\\r\\n\\t\\theight: 14px !important;\\r\\n\\t\\tmargin-left: 4px !important;\\r\\n\\t\\tmargin-right: 4px !important;\\r\\n\\t}\\r\\n}\\r\\n@media (max-width: 575px) {\\r\\n\\t.max-section-gallery .carousel .carousel-control-prev,\\r\\n\\t.max-section-gallery .carousel .carousel-control-next {\\r\\n\\t\\ttop: 123%;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel .carousel-control-prev {\\r\\n\\t\\tleft: 15%;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel .carousel-control-next {\\r\\n\\t\\tright: 15%;\\r\\n\\t}\\r\\n\\t.max-section-gallery .carousel-indicators {\\r\\n\\t\\ttop: 119% !important;\\r\\n\\t}\\r\\n}\\r\\n\\r\\n\\r\\n}\\r\\n/* Comprehensive fixes for iPad carousel arrows */\\r\\n\\r\\n/* General iPad fixes */\\r\\n@media only screen and (min-device-width: 768px) and (max-device-width: 1366px),\\r\\n       only screen and (min-width: 768px) and (max-width: 1366px) {\\r\\n  /* Ensure carousel overflow is visible */\\r\\n  .max-section-gallery .carousel {\\r\\n    overflow: visible !important;\\r\\n  }\\r\\n  \\r\\n  /* Ensure arrows are always visible */\\r\\n  .max-section-gallery .carousel .carousel-control-prev,\\r\\n  .max-section-gallery .carousel .carousel-control-next {\\r\\n    display: flex !important;\\r\\n    opacity: 1 !important;\\r\\n    visibility: visible !important;\\r\\n    z-index: 100;\\r\\n  }\\r\\n  \\r\\n  /* Make arrows more noticeable */\\r\\n  .max-section-gallery .carousel-control-prev-icon,\\r\\n  .max-section-gallery .carousel-control-next-icon {\\r\\n    background-color: rgba(0, 0, 0, 0.4);\\r\\n    border-radius: 50%;\\r\\n  }\\r\\n}\\r\\n\\r\\n/* Fix for standard iPad and iPad Mini */\\r\\n@media only screen and (min-device-width: 768px) and (max-device-width: 1023px),\\r\\n       only screen and (min-width: 768px) and (max-width: 1023px) {\\r\\n  .max-section-gallery .carousel .carousel-control-prev {\\r\\n    left: -6% !important;\\r\\n  }\\r\\n  \\r\\n  .max-section-gallery .carousel .carousel-control-next {\\r\\n    right: -6% !important;\\r\\n  }\\r\\n  \\r\\n  .max-section-gallery .carousel-control-prev-icon,\\r\\n  .max-section-gallery .carousel-control-next-icon {\\r\\n    width: 40px !important;\\r\\n    height: 40px !important;\\r\\n  }\\r\\n}\\r\\n\\r\\n/* Fix for iPad Pro */\\r\\n@media only screen and (min-device-width: 1024px) and (max-device-width: 1366px),\\r\\n       only screen and (min-width: 1024px) and (max-width: 1366px) {\\r\\n  .max-section-gallery .carousel .carousel-control-prev {\\r\\n    left: -5% !important;\\r\\n  }\\r\\n  \\r\\n  .max-section-gallery .carousel .carousel-control-next {\\r\\n    right: -5% !important;\\r\\n  }\\r\\n  \\r\\n  .max-section-gallery .carousel-control-prev-icon,\\r\\n  .max-section-gallery .carousel-control-next-icon {\\r\\n    width: 45px !important;\\r\\n    height: 45px !important;\\r\\n  }\\r\\n}\\r\\n\\r\\n/* Fix specifically for iPadOS versions that might have different rendering */\\r\\n@supports (-webkit-touch-callout: none) {\\r\\n  @media only screen and (min-device-width: 768px) and (max-device-width: 1366px),\\r\\n         only screen and (min-width: 768px) and (max-width: 1366px) {\\r\\n    .max-section-gallery .carousel .carousel-control-prev,\\r\\n    .max-section-gallery .carousel .carousel-control-next {\\r\\n      transform: translateY(-50%) !important; /* Keep vertical centering */\\r\\n    }\\r\\n  }\\r\\n}\\r\\n\u003c/style\u003e\\