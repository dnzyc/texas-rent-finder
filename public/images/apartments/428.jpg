taLayer"],"genre":["dataLayer"],"ratingCode":["dataLayer"],"brand":["dataLayer"],"elementType":["dataLayer"]}},"videoPlayer":{"module":{"moduleName":["dataLayer"],"bandName":["dataLayer"],"pageDepth":["dataLayer"],"interaction":["dataLayer"],"cardType":["dataLayer"],"carouselPosition":["dataLayer"]},"video":{"category":["dataLayer"],"title":["dataLayer"],"videoType":["dataLayer"],"contentID":["dataLayer"],"genre":["dataLayer"],"seasonNumber":["dataLayer"],"episodeNumber":["dataLayer"],"currentTime":["dataLayer"],"playerAction":["dataLayer"],"altText":["dataLayer"],"isPopupVideo":["dataLayer"],"autoplay":["dataLayer"]}},"gating":{"module":{"moduleName":["dataLayer"],"bandName":["dataLayer"],"headline":["dataLayer"],"pageDepth":["dataLayer"],"interaction":["dataLayer"]},"gate":{"gateAction":["dataLayer"],"gateElement":["dataLayer"],"gatedContentTitle":["dataLayer"]}},"email":{"module":{"moduleName":["dataLayer"],"bandName":["dataLayer"],"pageDepth":["dataLayer"]},"email":{"emailSubmissionSuccess":["dataLayer"],"b2bFieldValue":["dataLayer"]},"cta":{"text":["dataLayer"],"element":["dataLayer"],"destination":["dataLayer"]}}}},"frameworks":[],"relatedAppUrls":{"account":"https://auth.discoveryplus.com/account","addOn":"https://auth.discoveryplus.com/addon-picker","createAccount":"https://auth.discoveryplus.com/create-account","help":"https://help.discoveryplus.com","home":"https://www.discoveryplus.com","login":"https://auth.discoveryplus.com/login","play":"https://play.discoveryplus.com/","subscribe":"https://auth.discoveryplus.com/product"}},"authCookieName":"gi_ls","bcp":"en-US","brazeConfig":{"brazeEndpoint":null,"ek":null,"emailSignupSource":"launch_page","eps":""},"canonicalURL":"https://www.discoveryplus.com","cdnBaseUrl":"https://www.discoveryplus.com","contentType":"CMS","countryLangUris":{"it/it":{"url":"/it/it","startDate":null,"endDate":null},"de/de":{"url":"/de/de","startDate":null,"endDate":null},"at/de":{"url":"/at/de","startDate":null,"endDate":null},"ie/en":{"url":"/ie/en","startDate":null,"endDate":null},"gb/en":{"url":"/gb/en","startDate":null,"endDate":null},"no/no":{"url":"/no/no","startDate":null,"endDate":null},"se/sv":{"url":"/se/sv","startDate":null,"endDate":null}},"countryMappings":[{"language":"en","countryCode":"us","bcp47Code":"en-US"}],"countryToRegion":{"ca":"ca","de":"emea","vg":"emea","fk":"emea","gi":"emea","vi":"amer","in":"apac","at":"emea","se":"emea","sj":"emea","gu":"amer","va":"emea","gg":"emea","it":"emea","as":"amer","pr":"amer","um":"amer","je":"emea","sm":"emea","ie":"emea","kn":"emea","no":"emea","gb":"emea","mp":"amer","us":"amer"},"enableLFE":false,"environment":"prd","experimentConfigs":[],"eventScheduleDates":null,"formattedURL":"/","geoRedirectFunction":"function initGeoRedirect({\n  countryLangUris,\n  geoRedirectUrl,\n  isUserOutOfRegion,\n  userCountry,\n  countryMappings\n}) {\n  // Only run in browser environment, need a defined window\n  if (globalThis.window === undefined) {\n    return;\n  }\n  // Bot user agents that should not be redirected\n  const BOT_USER_AGENTS = ['adidxbot', 'adsbot-google', 'adsbot-google-mobile', 'adsbot-google-mobile-apps', 'apis-google', 'baiduspider', 'bingbot', 'bingpreview', 'coccocbot', 'contentking', 'crazyegg', 'duplexweb-google', 'facebookexternalhit', 'feedfetcher-google', 'google favicon', 'google-read-aloud', 'googlebot', 'googleweblight', 'mail.ru_bot', 'mediapartners-google', 'onetrustbot', 'se 2.x metasr 1.0', 'storebot-google', 'twitterbot', 'y!j-srd', 'yahoo! slurp', 'yowser'];\n  // Global pages that should not be redirected (including subpages)\n  const GLOBAL_PAGES = ['/geo-availability', '/privacy', '/terms-of-use'];\n  // Duplicate of COOKIE_NAMES from constants/cookies.ts.\n  // We'll use this to avoid importing the constants file, because we can't use imports when babel transforming this function into a string.\n  const COOKIE_NAMES = {\n    SELECTED_LANGUAGE: 'selectedLanguage',\n    USER_ON_PREFERRED_URL: 'userOnPreferredUrl'\n  };\n  // Instead of using js-cookie, we'll use the document.cookie API to set the cookie value.\n  // This is because we can't use imports when babel transforming this function into a string.\n  const setCookie = (name, value) =\u003e {\n    document.cookie = `${name}=${value}; path=/`;\n  };\n  // Instead of using js-cookie, we'll use the document.cookie API to get the cookie value.\n  // This is because we can't use imports when babel transforming this function into a string.\n  const getCookie = name =\u003e {\n    const cookies = `; ${document.cookie}`;\n    const cookieParts = cookies.split(`; ${name}=`);\n    if (cookieParts.length === 2) {\n      // Extract value before the next semicolon (or end of string)\n      return cookieParts[1].split(';')[0];\n    }\n    return undefined;\n  };\n  const isBot = userAgent =\u003e {\n    const lowerUserAgent = userAgent.toLowerCase();\n    return BOT_USER_AGENTS.some(bot =\u003e lowerUserAgent.includes(bot.toLowerCase()));\n  };\n  const isGlobalPage = url =\u003e GLOBAL_PAGES.some(page =\u003e url.includes(page));\n  // --------------------------------------------------------------------------------\n  // TODO: This is a copy of the function in handleLocalizationRefresh.ts. We should refactor this to avoid duplication.\n  // We'll need to remove this header injection logic and probably use middleware or proxy to handle this.\n  // We'll also need Bolt to be implemented on the server side to handle this.\n  const getLanguagePath = (languageBcp47Code, userCountry, countryLangUris, countryMappings) =\u003e {\n    if (!languageBcp47Code || !countryMappings || !countryLangUris || !userCountry) {\n      const missingParams = [];\n      if (!languageBcp47Code) {\n        missingParams.push('languageBcp47Code');\n      }\n      if (!countryMappings) {\n        missingParams.push('countryMappings');\n      }\n      if (!countryLangUris) {\n        missingParams.push('countryLangUris');\n      }\n      if (!userCountry) {\n        missingParams.push('userCountry');\n      }\n      console.error(`Cannot get language path: missing required parameters. Missing: ${missingParams.join(', ')}`);\n      return;\n    }\n    // We can only redirect to the user's country, so we first check the userCountry and then the languageBcp47Code\n    const countryMapping = countryMappings.find(mapping =\u003e mapping.countryCode === userCountry.toLowerCase() \u0026\u0026 mapping.bcp47Code === languageBcp47Code);\n    // No redirect if the country mapping is not found\n    if (!countryMapping) {\n      return;\n    }\n    const {\n      countryCode,\n      language\n    } = countryMapping;\n    const countryLanguageKey = `${countryCode}/${language}`;\n    const countryLanguageUri = countryLangUris[countryLanguageKey];\n    // No matching pair or language found\n    if (!countryLanguageUri || !language) {\n      return;\n    }\n    const {\n      url: countryLanguagePath,\n      startDate,\n      endDate\n    } = countryLanguageUri;\n    // Check if content is within availability window\n    const isPageAvailable = (() =\u003e {\n      // If startDate and endDate are falsy, the page is always available\n      if (!startDate \u0026\u0026 !endDate) {\n        return true;\n      }\n      const currDate = Date.now();\n      const start = startDate ? Date.parse(startDate) : 0;\n      const end = endDate ? Date.parse(endDate) : Infinity;\n      // Validate parsed dates - if parsing fails, treat as unavailable\n      if (Number.isNaN(start) || Number.isNaN(end)) {\n        console.warn(`Invalid date format in countryLangUri: startDate=\"${startDate}\", endDate=\"${endDate}\"`);\n        return false;\n      }\n      // If the current date is between start and end, the page is available\n      return start \u003c= currDate \u0026\u0026 currDate \u003c= end;\n    })();\n    // No redirect if content is not available\n    if (!isPageAvailable) {\n      return;\n    }\n    // Remove country/lang prefix for US Englis